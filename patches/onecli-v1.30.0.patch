+// PoC-5 専用エントリ: agent-runner を二層構造 (host + per-session container)
+// なしで単体実行し、Vertex × Claude (claude-sonnet-4-6) に 1 turn 推論を
+// 投げて stdout に応答テキストを出して exit する最小コード。
+//
+// 経路 (Pod manifest 側で env 配線): nanoclaw container -> HTTPS_PROXY
+// (localhost:10255 = OneCLI sidecar v1.30.0 MITM) -> aiplatform.googleapis.com
+// (Vertex × Claude)。OneCLI secret store に投入された Vertex Bearer token を
+// proxy が `Authorization: Bearer {value}` で注入する。
+//
+// 詳細な改変方針: ../../../patches/PLAN.md (改変ポイント ①④)
+import { ClaudeProvider } from './providers/claude.js';
+
+const prompt = process.env.POC5_PROMPT ?? 'Reply with exactly the token: BIBLIO_POC5_OK';
+const cwd = process.env.POC5_CWD ?? '/tmp';
+const model = process.env.POC5_MODEL ?? process.env.ANTHROPIC_MODEL ?? 'claude-sonnet-4-6';
+
+const provider = new ClaudeProvider({ model });
+const q = provider.query({ prompt, cwd });
+
+let resultText: string | null = null;
+let errorMessage: string | null = null;
+
+for await (const ev of q.events) {
+  if (ev.type === 'result') {
+    resultText = ev.text;
+    process.stdout.write(`[poc5] result: ${resultText ?? ''}\n`);
+  } else if (ev.type === 'error') {
+    errorMessage = ev.message;
+    process.stderr.write(`[poc5] error: ${ev.message}\n`);
+  }
+}
+
+if (errorMessage !== null || resultText === null) {
+  process.stderr.write('[poc5] FAIL: no result event\n');
+  process.exit(1);
+}
+
+process.stdout.write('[poc5] DONE\n');
+process.exit(0);
