# biblio-claw — env テンプレート (local / GKE 共通のキー一覧)
#
# 使い方:
#   - local: `cp .env.example .env` して実値を埋める。`.env` は gitignore 済み
#     (絶対にコミットしない)。
#   - GKE: 本ファイル自体は Pod へマウントしない。envFrom secretRef 経由で
#     process.env に注入する (例: biblio-slack-tokens Secret) — 入れるべき
#     キー名のリファレンスとして本ファイルを参照する。
#
# 各値の consumer はコード側で readEnvFile() が個別に拾う (`<cwd>/.env` 優先、
# 不足キーは `process.env` から補完。詳細は src/env.ts の JSDoc を参照)。
# ここはキーの一覧と既定値の手本を兼ねる。

# === Vertex (Claude on Vertex AI) =========================================
# claude provider (src/providers/claude.ts) が agent コンテナへ伝搬する。
# project / region は確定値 (Vault design/tech-stack.md: global / sonnet-4-6)。
ANTHROPIC_VERTEX_PROJECT_ID=hajimari-ai-hackathon-2026
CLOUD_ML_REGION=global

# === biblio 検品 (Phase 2+) ===============================================
# src/biblio/vertex-client.ts が dangerous 軸の VERDICT 判定に使う Vertex 上の
# モデル ID。**未設定だと検品が起動エラー → fail-closed で HOLD/inspect_error**
# (既定値はコードに置かない方針 = モデル選択は env / secret manager で明示)。
# 既定の Gemini 2.5 Flash は Google 1st party = Marketplace enable 不要。
# 用途規約 (CLAUDE.md): 本キーは NanoClaw ネイティブの補助推論 (skill 発動非関連)
# にのみ使用。skill 発動に絡む推論 (カテゴライズ等) は Anthropic 必須。
INSPECT_DANGEROUS_MODEL=gemini-2.5-flash

# === biblio カテゴライズ (Phase 3) ========================================
# src/biblio/categorize.ts が 4 namespace (biblio-dev/art/bf/ai) 判定に使う
# Vertex × Anthropic on Vertex のモデル ID。`publishers/anthropic/.../:rawPredict`
# 経路で叩く。skill 発動絡みの推論 = Anthropic 必須 (用途規約 / CLAUDE.md)。
# Sonnet-4.6 は Vertex Marketplace で project 個別 enable が必要だが、
# Phase 3 Task 0 (2026-06-20) で hajimari-ai-hackathon-2026 上で enable 確認済。
# モデル ID に日付サフィックス (@20251101 等) は付けない (= Sonnet 4.6 では存在しない、GOTCHA-2)。
CATEGORIZE_MODEL=claude-sonnet-4-6

# === biblio 陳列 (Phase 3) ================================================
# src/biblio/shelve.ts が PR を作る棚リポ (PRD B §解決策の詳細で確定)。
SHELF_REPO_OWNER=HajimariInc
SHELF_REPO_NAME=biblio-shelf

# 陳列 commit/PR の author 表記 (GH App identity = `hj-biblio-github-app[bot]`)。
# Phase 3 Task 0 (2026-06-20) で実機確認した値:
#   - GH App slug = hj-biblio-github-app (= 実 app の slug、`biblio-claw` ではない)
#   - BOT_USER_ID = 292998322 (= GET /users/hj-biblio-github-app[bot] の id)
# email は `<BOT_USER_ID>+<slug>[bot]@users.noreply.github.com` 形式が正書き
# (commit を bot account に紐づけるための GitHub 規約)。
SHELF_PR_AUTHOR_NAME=hj-biblio-github-app[bot]
SHELF_PR_AUTHOR_EMAIL=292998322+hj-biblio-github-app[bot]@users.noreply.github.com

# GH App 経路で `POST /git/commits` が 4xx に倒れたときの fallback 値 (DEN さん名義 PAT)。
# 形式: `Name <email>` (= GH commit author の標準形式)。空なら fallback しない (GH App のみ)。
# PRD B §意思決定ログ「棚リポ PR の commit author 表記」で「不都合判明時 DEN さん名義 PAT に fallback」と確定。
# 例: SHELF_PR_AUTHOR_FALLBACK='MAXiDEN <claude@wforest.jp>'
SHELF_PR_AUTHOR_FALLBACK=

# === OneCLI gateway =======================================================
# host (src/config.ts) と secret 投入スクリプトが参照。AUTH_MODE=local 運用の
# ため API キーは空でよい (REST は :10254/v1、proxy は :10255)。
ONECLI_URL=http://localhost:10254
ONECLI_API_KEY=

# === Slack (Socket Mode) ==================================================
# Slack adapter (src/channels/slack.ts) が参照。Socket Mode は ingress 不要で
# xapp- の App-Level Token (connections:write) と xoxb- の Bot Token を使う。
# 値は DEN さんが Slack app から発行 (argv/ログ非露出)。
#
# local↔GKE の bot 分離 (M2 PRD A Phase 2):
#   - local: 別の Slack App (mention @biblio-dev) の token をここに入れる。
#     GKE 本番 App (@biblio) と同一 workspace で共存しても bot user ID が違う
#     ため mention 衝突は起きない。
#   - GKE: 本ファイルからは読まない。biblio-slack-tokens Secret に投入し
#     envFrom secretRef で StatefulSet に注入する (= .env への記載は local 専用)。
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# === Assistant identity (M2 PRD A Phase 2) ================================
# src/config.ts:ASSISTANT_NAME。@<name> mention の規定値 + agent の自己認識に効く。
# local では @biblio-dev に合わせて 'biblio-dev'、GKE StatefulSet では yaml の
# env で 'biblio' を明示するため、本ファイルは local 既定値のみ持つ。
ASSISTANT_NAME=biblio-dev

# === init-first-agent bootstrap (M2 PRD A Phase 2) ========================
# scripts/init-first-agent-{local,gke}.sh が参照する。両 wrapper は環境ごとに
# 別の wiring を組むため、local 用 (= @biblio-dev との DM) と GKE 用 (= @biblio
# との DM) は **値が異なる**。両方を同じ .env に置く場合は、GKE 用は wrapper
# 実行時に shell 変数で override する想定 (例: SLACK_OWNER_DM_CHANNEL_ID=Dxxxx
# bash scripts/init-first-agent-gke.sh)。
#
# SLACK_OWNER_USER_ID: Slack 上の DEN さん user ID (例: U0ABC123XY)
# SLACK_OWNER_DM_CHANNEL_ID: bot ↔ DEN さん の DM チャネル ID (例: D0AAA1234B)
# SLACK_OWNER_DISPLAY_NAME: agent_groups の owner user の display_name
SLACK_OWNER_USER_ID=
SLACK_OWNER_DM_CHANNEL_ID=
SLACK_OWNER_DISPLAY_NAME=DEN

# === GitHub App (Sidecar 経由で OneCLI に installation token を投入) ========
# scripts/onecli-gh-secret.sh が参照。PEM → RS256 JWT → installation token を
# 発行して OneCLI secret に upsert する (= 司書 agent から `gh` で api.github.com
# に到達できる経路の認可を OneCLI 側に集約)。token 有効期限は ~60min、ローカル
# (docker compose) は手動再実行で更新 (PATCH 200)。GKE 経路は M2 PRD A Phase 3
# 以降、orchestrator Pod 内の gh-token-rotator Native sidecar が自動再投入する
# (旧 CronJob `biblio-sidecar` は廃止)。
# 値は DEN さんが GitHub App から発行 (App ID + Installation ID + PEM)。
GH_APP_ID=
GH_INSTALLATION_ID=
# PEM ファイルのローカルパス (例: .secrets/biblio-gh-app.pem を推奨)。
# .gitignore で .secrets/ ディレクトリと *.pem を deny 済み。
# PEM 値は env / argv に乗せず、cat | node の pipe 完結で扱う。
GH_APP_PEM_PATH=
GH_API_HOST=api.github.com
GH_SECRET_NAME=biblio-claw-gh-token
GH_SECRET_HEADER=authorization
# shell の brace expansion 回避のため必ず quote する (= `set -a; . .env;` で読まれるため)
GH_SECRET_VALUE_FORMAT='Bearer {value}'
# JWT_EXP_SECONDS = exp を「現在時刻から何秒後」に設定するか。
# iat = now - 60 (クロックドリフト吸収) なので、JWT 有効期間 (exp - iat) =
# JWT_EXP_SECONDS + 60。既定 540 + 60 = 600 秒 = 10 分 (GitHub 上限ちょうど)。
JWT_EXP_SECONDS=540

# === Container (任意) ======================================================
# agent コンテナの image (既定は install-slug 由来の per-checkout タグ)。
# GKE では Artifact Registry のフル ref を渡す。
# CONTAINER_IMAGE=

# === Container runtime (環境分離アダプタ) ===================================
# agent コンテナの spawn 方式。local 開発は `docker` (既定)、GKE は `k8s` を
# 指定して Batch v1 Job として spawn する (k8s/02-orchestrator-rbac.yaml の RBAC が前提)。
# CONTAINER_PROVIDER=docker

# K8sJobProvider が createNamespacedJob namespace + Informer path に使う。
# CONTAINER_PROVIDER=k8s のときのみ参照。
# BIBLIO_NAMESPACE=biblio-claw
