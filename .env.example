# biblio-claw — local 結線用 env テンプレート
#
# 使い方: `cp .env.example .env` して実値を埋める。`.env` は gitignore 済み
# (絶対にコミットしない)。各値の consumer はコード側で readEnvFile() が個別に
# 拾うため、ここはキーの一覧と既定値の手本を兼ねる。

# === Vertex (Claude on Vertex AI) =========================================
# claude provider (src/providers/claude.ts) が agent コンテナへ伝搬する。
# project / region は確定値 (Vault design/tech-stack.md: global / sonnet-4-6)。
ANTHROPIC_VERTEX_PROJECT_ID=hajimari-ai-hackathon-2026
CLOUD_ML_REGION=global

# === OneCLI gateway =======================================================
# host (src/config.ts) と secret 投入スクリプトが参照。AUTH_MODE=local 運用の
# ため API キーは空でよい (REST は :10254/v1、proxy は :10255)。
ONECLI_URL=http://localhost:10254
ONECLI_API_KEY=

# === Slack (Socket Mode) ==================================================
# Slack adapter (src/channels/slack.ts) が参照。Socket Mode は ingress 不要で
# xapp- の App-Level Token (connections:write) と xoxb- の Bot Token を使う。
# 値は DEN さんが Slack app から発行 (argv/ログ非露出)。
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# === Container (任意) ======================================================
# 既定は install-slug 由来の per-checkout タグ。上書きする場合のみ設定。
# CONTAINER_IMAGE=
