# biblio-claw — env テンプレート (local / GKE 共通のキー一覧)
#
# 使い方:
#   - local: `cp .env.example .env` して実値を埋める。`.env` は gitignore 済み
#     (絶対にコミットしない)。
#   - GKE: 本ファイル自体は Pod へマウントしない。envFrom secretRef 経由で
#     process.env に注入する (例: biblio-slack-tokens Secret) — 入れるべき
#     キー名のリファレンスとして本ファイルを参照する。
#
# 各値の consumer はコード側で readEnvFile() が個別に拾う (`<cwd>/.env` 優先、
# 不足キーは `process.env` から補完。詳細は src/env.ts の JSDoc を参照)。
# ここはキーの一覧と既定値の手本を兼ねる。

# === Vertex (Claude on Vertex AI) =========================================
# claude provider (src/providers/claude.ts) が agent コンテナへ伝搬する。
# project / region は確定値 (Vault design/tech-stack.md: global / sonnet-4-6)。
ANTHROPIC_VERTEX_PROJECT_ID=hajimari-ai-hackathon-2026
CLOUD_ML_REGION=global

# === M4-A observability (Cloud Trace + BigQuery sink) =====================
# scripts/verify-m4-a.sh が要求する必須 env (= preflight で fail-fast)。
# - GCP_PROJECT_ID: Cloud Trace + BQ query 対象 project。実体は ANTHROPIC_VERTEX_PROJECT_ID
#   と同値だが、observability 文脈では project の semantic が違う (= LLM 経路ではなく
#   trace/log 経路) ため別 key として持つ。将来 LLM project と observability project を
#   分離する余地も残す。
# - BQ_DATASET_ID: terraform/m4-a-observability/variables.tf の default と一致。
#   sink 経由で `stdout_YYYYMMDD` / `stderr_YYYYMMDD` テーブルが生成される dataset。
GCP_PROJECT_ID=hajimari-ai-hackathon-2026
BQ_DATASET_ID=llm_observability

# === biblio 仕入れ (Phase 2: individual-skill-shiire) =====================
# src/biblio/acquire.ts が repo 全体仕入れ時の skill 数閾値判定に使う。
# 仕入先 repo の skill 数がこの値を超えたら git clone する前に early return し、
# patron に個別指定 (`@bot 仕入れて <owner>/<repo>/<skill>`) を促す。
# 既定 10 の根拠: `MAX_BLOBS_PER_PR=100` を割って 1 skill あたり平均 10 ファイル以下なら
# 1 仕入れ = 1 PR で陳列できる目安。不正値 (0 以下 / 数値以外) は default に倒れ warn 出力。
# ACQUIRE_SKILL_THRESHOLD=10

# === biblio 検品 (Phase 2+) ===============================================
# src/biblio/vertex-client.ts が dangerous 軸の VERDICT 判定に使う Vertex 上の
# モデル ID。**未設定だと検品が起動エラー → fail-closed で HOLD/inspect_error**
# (既定値はコードに置かない方針 = モデル選択は env / secret manager で明示)。
# 既定の Gemini 2.5 Flash は Google 1st party = Marketplace enable 不要。
# 用途規約 (CLAUDE.md): 本キーは NanoClaw ネイティブの補助推論 (skill 発動非関連)
# にのみ使用。skill 発動に絡む推論 (カテゴライズ等) は Anthropic 必須。
INSPECT_DANGEROUS_MODEL=gemini-2.5-flash

# === biblio カテゴライズ (Phase 3) ========================================
# src/biblio/categorize.ts が 4 namespace (biblio-dev/art/bf/ai) 判定に使う
# Vertex × Anthropic on Vertex のモデル ID。`publishers/anthropic/.../:rawPredict`
# 経路で叩く。skill 発動絡みの推論 = Anthropic 必須 (用途規約 / CLAUDE.md)。
# Sonnet-4.6 は Vertex Marketplace で project 個別 enable が必要 (= 別 project に切り替えた
# 場合は再 enable してから使う)。モデル ID に日付サフィックス (@20251101 等) は付けない
# (= Sonnet 4.6 では存在しない、GOTCHA-2)。
CATEGORIZE_MODEL=claude-sonnet-4-6

# === biblio 陳列 (Phase 3) ================================================
# src/biblio/shelve.ts が PR を作る棚リポ (PRD B §解決策の詳細で確定)。
# SHELF_REPO_OWNER は scripts/onecli-gh-secret.sh の secret 投入先 owner 解決と、
# verify-m2/m3/slack-e2e-gke 等の cleanup 処理 (gh pr close 等) で参照する必須 env。
# pathPattern は issue #36 (2026-06-24 解消、PR #38) 経緯で省略 = 全パスマッチに統一
# (= GKE で injection skip される不具合の唯一の dependable な回避経路、CLAUDE.md §設計原則参照)。
# デフォルト値はスクリプト側に置かず、必須 env 化で fork / 別案件での silent 罠を回避 (PR #10)。
SHELF_REPO_OWNER=HajimariInc
SHELF_REPO_NAME=biblio-shelf

# 陳列 commit/PR の author 表記 (GH App identity = `hj-biblio-github-app[bot]`)。
# 既定値の根拠 (GH App 再作成時や別 App を使う場合はここを更新):
#   - GH App slug = hj-biblio-github-app (= 実 app の slug、`biblio-claw` ではない)
#   - BOT_USER_ID = 292998322 (= `GET /users/hj-biblio-github-app[bot]` の id)
# email は `<BOT_USER_ID>+<slug>[bot]@users.noreply.github.com` 形式が正書き
# (commit を bot account に紐づけるための GitHub 規約)。
SHELF_PR_AUTHOR_NAME=hj-biblio-github-app[bot]
SHELF_PR_AUTHOR_EMAIL=292998322+hj-biblio-github-app[bot]@users.noreply.github.com

# GH App 経路で `POST /git/commits` が 4xx に倒れたときの fallback 値 (DEN さん名義 PAT)。
# 形式: `Name <email>` (= GH commit author の標準形式)。空なら fallback しない (GH App のみ)。
# PRD B §意思決定ログ「棚リポ PR の commit author 表記」で「不都合判明時 DEN さん名義 PAT に fallback」と確定。
# 例: SHELF_PR_AUTHOR_FALLBACK='MAXiDEN <claude@wforest.jp>'
SHELF_PR_AUTHOR_FALLBACK=

# === OneCLI gateway =======================================================
# host (src/config.ts) と secret 投入スクリプトが参照。AUTH_MODE=local 運用の
# ため API キーは空でよい (REST は :10254/v1、proxy は :10255)。
ONECLI_URL=http://localhost:10254
ONECLI_API_KEY=

# === Slack (Socket Mode) ==================================================
# Slack adapter (src/channels/slack.ts) が参照。Socket Mode は ingress 不要で
# xapp- の App-Level Token (connections:write) と xoxb- の Bot Token を使う。
# 値は DEN さんが Slack app から発行 (argv/ログ非露出)。
#
# local↔GKE の bot 分離 (M2 PRD A Phase 2):
#   - local: 別の Slack App (mention @biblio-dev) の token をここに入れる。
#     GKE 本番 App (@biblio) と同一 workspace で共存しても bot user ID が違う
#     ため mention 衝突は起きない。
#   - GKE: 本ファイルからは読まない。biblio-slack-tokens Secret に投入し
#     envFrom secretRef で StatefulSet に注入する (= .env への記載は local 専用)。
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# === Assistant identity (M2 PRD A Phase 2) ================================
# src/config.ts:ASSISTANT_NAME。@<name> mention の規定値 + agent の自己認識に効く。
# local では @biblio-dev に合わせて 'biblio-dev'、GKE StatefulSet では yaml の
# env で 'biblio' を明示するため、本ファイルは local 既定値のみ持つ。
ASSISTANT_NAME=biblio-dev

# === init-first-agent bootstrap (M2 PRD A Phase 2) ========================
# scripts/init-first-agent-{local,gke}.sh が参照する。両 wrapper は環境ごとに
# 別の wiring を組むため、local 用 (= @biblio-dev との DM) と GKE 用 (= @biblio
# との DM) は **値が異なる**。両方を同じ .env に置く場合は、GKE 用は wrapper
# 実行時に shell 変数で override する想定 (例: SLACK_OWNER_DM_CHANNEL_ID=Dxxxx
# bash scripts/init-first-agent-gke.sh)。
#
# SLACK_OWNER_USER_ID: Slack 上の DEN さん user ID (例: U0ABC123XY)
# SLACK_OWNER_DM_CHANNEL_ID: bot ↔ DEN さん の DM チャネル ID (例: D0AAA1234B)
# SLACK_OWNER_DISPLAY_NAME: agent_groups の owner user の display_name
SLACK_OWNER_USER_ID=
SLACK_OWNER_DM_CHANNEL_ID=
SLACK_OWNER_DISPLAY_NAME=DEN

# === GitHub App (Sidecar 経由で OneCLI に installation token を投入) ========
# scripts/onecli-gh-secret.sh が参照。PEM → RS256 JWT → installation token を
# 発行して OneCLI secret に upsert する (= 司書 agent から `gh` で api.github.com
# に到達できる経路の認可を OneCLI 側に集約)。token 有効期限は ~60min、ローカル
# (docker compose) は手動再実行で更新 (PATCH 200)。GKE 経路は M2 PRD A Phase 3
# 以降、orchestrator Pod 内の gh-token-rotator Native sidecar が自動再投入する
# (旧 CronJob `biblio-sidecar` は廃止)。
# 値は DEN さんが GitHub App から発行 (App ID + Installation ID + PEM)。
GH_APP_ID=
GH_INSTALLATION_ID=
# PEM ファイルのローカルパス (例: .secrets/biblio-gh-app.pem を推奨)。
# .gitignore で .secrets/ ディレクトリと *.pem を deny 済み。
# PEM 値は env / argv に乗せず、cat | node の pipe 完結で扱う。
GH_APP_PEM_PATH=
GH_API_HOST=api.github.com
GH_SECRET_NAME=biblio-claw-gh-token
GH_SECRET_HEADER=authorization
# shell の brace expansion 回避のため必ず quote する (= `set -a; . .env;` で読まれるため)
GH_SECRET_VALUE_FORMAT='Bearer {value}'
# JWT_EXP_SECONDS = exp を「現在時刻から何秒後」に設定するか。
# iat = now - 60 (クロックドリフト吸収) なので、JWT 有効期間 (exp - iat) =
# JWT_EXP_SECONDS + 60。既定 540 + 60 = 600 秒 = 10 分 (GitHub 上限ちょうど)。
JWT_EXP_SECONDS=540

# === Container (任意) ======================================================
# agent コンテナの image (既定は install-slug 由来の per-checkout タグ)。
# GKE では Artifact Registry のフル ref を渡す。
# CONTAINER_IMAGE=

# === Container runtime (環境分離アダプタ) ===================================
# agent コンテナの spawn 方式。local 開発は `docker` (既定)、GKE は `k8s` を
# 指定して Batch v1 Job として spawn する (k8s/02-orchestrator-rbac.yaml の RBAC が前提)。
# CONTAINER_PROVIDER=docker

# K8sJobProvider が createNamespacedJob namespace + Informer path に使う。
# CONTAINER_PROVIDER=k8s のときのみ参照。
# BIBLIO_NAMESPACE=biblio-claw

# === biblio 装備 (M3 Phase 1+) =============================================
# resolveEquippedBiblios() (src/biblio/equip.ts) が読む装備リスト (csv)。
# 形式: <owner>--<name> (BIBLIO_NAME_RE 形式)、複数件はカンマ区切り。
# 未設定 or 空 = 装備なし (agent コンテナに /workspace/biblios/ mount は生えない)。
# Phase 2 で session 単位 DB lookup (= session_equipped_biblios テーブル) に移行済。
# 本 env は test only バックドア (= DB を持たないユニットテストで装備リストを直接差し込む
# 目的、`src/biblio/equip.ts:9-14` 参照)。**本番経路では未設定のまま** (= 常に DB lookup)。
# 例: BIBLIO_EQUIPPED_NAMES=HajimariInc--biblio-shelf,nanocoai--nanoclaw
# BIBLIO_EQUIPPED_NAMES=

# === host-sweep idle cleanup =================================================
# AGENT_IDLE_THRESHOLD_MS: src/host-sweep.ts が agent container を idle 判定して
#   kill するまでの heartbeat 経過時間 (ms)。`kill-idle` path は claims 空 + Bash
#   未宣言の running container のみ対象 (= stuck 用の `kill-ceiling` 30 min とは
#   別の直交 path)。
#   GKE 経路では agent Pod が orchestrator PVC の zone affinity を継承するため、
#   会話完了済の idle Pod が memory を占有して新規 spawn 要求が Pending で固まる
#   問題の対症 (docs/operations-runbook.md §Pending Pod 参照)。
#   未設定 = 300000 (= 5 min)。短すぎ (1-2 min) は spawn-kill 反復で体感遅延増、
#   長すぎ (15 min+) は効きが薄い。invalid 値 (非数値 / <=0) は default に warn log
#   付きフォールバック。
# AGENT_IDLE_THRESHOLD_MS=300000

# === ログ設定 ================================================================
# LOG_FORMAT: ログ形式 (json | text)。GCP では json (Cloud Logging が jsonPayload として
#   自動解析する規約)、ローカル開発は text を推奨 (色付きで読みやすい)。
LOG_FORMAT=text
# LOG_COMPONENT: ログ出力時の component フィールド名 (= Cloud Logging で絞り込みに使う)。
#   host orchestrator は `host` がデフォルト (= unset 時)。
#   K8s 経路では Pod 内 container ごとに個別の component を投入する (= orchestrator-statefulset.yaml)。
LOG_COMPONENT=host
# LOG_LEVEL: 出力 threshold (debug | info | warn | error | fatal)。既定 info。
#   GKE で debug を増やしたい場合は k8s manifest 側で個別 container に投入する。
# LOG_LEVEL=info

# === M4-E Fugue channel adapter (Phase 1-3: local-foundation + consult + equip-hitl) ====
# Fugue Cloud Run から biblio-claw に接続するための HTTP endpoint の設定。
# Phase 1 で skeleton (Bearer auth + path routing + 200/401/404/400/413/500) 完成、
# Phase 2 で consult (蔵書検索) を full spec 実装済 (listBiblio 経由の substring match +
# top 10 truncate + 部分失敗 200+status:'error'+warnings 経路 + M4-A biblio.list span 相乗り)。
# Phase 3 で equip (装備) + HITL 政策 (fugue_equipped_biblios channel-scoped store) を
# full spec 実装済、Phase 5 で Prod deploy 予定。
#
# consult は SHELF_REPO_OWNER / SHELF_REPO_NAME (本ファイル上部) にも依存する。未設定時は
# 200 + status:'error' + warnings=['consult failed: env_missing'] を返す (5xx は出さない)。
#
# FUGUE_SHARED_TOKEN: Fugue Cloud Run から送られる Bearer token の期待値。
#   local dev では次で生成: `openssl rand -hex 32`
#   Prod (Phase 5) は Secret Manager `fugue-shared-token` から envFrom secretRef 経由で注入
#   (`k8s/10-orchestrator-statefulset.yaml` の envFrom に `biblio-fugue-shared-token` を追加、
#   `optional: false` = Pod 起動時に fail-fast で silent skip 防止)。
#   空 or 未設定なら Fugue adapter は起動しない (credential 欠落 warn ログのみ、
#   Slack adapter と対称)。
FUGUE_SHARED_TOKEN=
# FUGUE_HTTP_PORT: HTTP listen port。既定 8080。
# FUGUE_HTTP_PORT=8080
# FUGUE_HTTP_HOST: bind host。既定 127.0.0.1 (local 安全側)。
#   docker / GKE (Phase 5) 経路では **必ず 0.0.0.0 に切替**。Pod IP に bind し LB からの
#   流入を受ける = 127.0.0.1 のままだと LB から到達不能 (silent failure)。
#   GKE StatefulSet では manifest 側で `FUGUE_HTTP_HOST=0.0.0.0` を明示投入済
#   (`k8s/10-orchestrator-statefulset.yaml`)。
# FUGUE_HTTP_HOST=127.0.0.1
# FUGUE_URL: fake-fugue-client 実行時の Prod HTTPS URL 発火用 (M4-E Phase 5)。
#   **`.env` には書かない** (公開ポリシー: ホスト名は Secret Manager `fugue-domain-name` を
#   Source of Truth とする、静的ファイル露出しない)。
#   Prod verify 時はセッション先頭で 1 回取得 + export する運用:
#     export FUGUE_URL="https://$(gcloud secrets versions access latest \
#       --secret=fugue-domain-name --project=hajimari-ai-hackathon-2026)"
#   未設定なら `FUGUE_HTTP_HOST` + `FUGUE_HTTP_PORT` を使う local docker compose 経路。
# FUGUE_URL=

# --- M4-E Phase 6: verify-fugue-channel.sh 用 env (verify-m4-b と対称) ---
# 全 3 個とも default 値があるため、通常は未設定でよい。上書きしたい場合のみセット。
#
# VERIFY_FUGUE_TEST_SKILL_ID: Section 2 (local equip) / Section 9 (Prod equip) で発火する
#   skill_id (biblio 名)。default = 'example-org--test-biblio-minimal' (棚に存在する前提)。
#   棚に無ければ 200 + not_found 応答で verify は継続 (channel 分離 row assert は skip される)。
# VERIFY_FUGUE_TEST_SKILL_ID=example-org--test-biblio-minimal
#
# VERIFY_FUGUE_ORCHESTRATOR_POD: Prod verify (Section 5-10) で kubectl exec する pod 名。
#   default = 'biblio-orchestrator-0' (StatefulSet の ordinal 0)。
# VERIFY_FUGUE_ORCHESTRATOR_POD=biblio-orchestrator-0
#
# VERIFY_FUGUE_NAMESPACE: Prod verify で kubectl を実行する namespace。
#   default = 'biblio-claw' (k8s/00-namespace.yaml の値)。
# VERIFY_FUGUE_NAMESPACE=biblio-claw
#
# VERIFY_FUGUE_INCLUDE_INTEGRATION: 予約 (Phase 6 では未使用、将来 Fugue チーム合同 verify の
#   opt-in flag)。設定しても現時点では影響なし。Fugue 側 `verify-biblio-integration.sh` が
#   確定した段階で `verify-fugue-channel.sh` から呼び出す経路を追加する余地。
# VERIFY_FUGUE_INCLUDE_INTEGRATION=

# === M4-F Phase 2: gate agent (routing + injection defense) ===============
# gate 4 層 (pattern → escape → XML → LLM evaluator) は既定 OFF。有効化すると
# router.ts + fugue-http.ts の fan-out loop 前段で 3 分類 (`biblio-adk` /
# `biblio-other` / `in-secure`) 判定が走り、routing は分類 → provider mismatch
# skip、in-secure は 3 点セット (admin DM 通知 + audit log + patron 定型文返信)。
#
# GATE_ENABLED: '1' or 'true' で有効化。既定 (未設定 / それ以外) は無効化。
#   local docker smoke (`GATE_ENABLED=true`) では init-hybrid-agent.ts の
#   `wireSlackDm` fail-fast が緩和され、既存 ADK wire + hybrid 両 wire が並置
#   (fan-out 二重発火は gate の provider mismatch skip で構造的に抑止)。
#   GKE で有効化する際は StatefulSet env に追加 + `messaging_group_agents` の
#   両 wire を先に確立してから rollout restart する順序 (詳細: runbook §M4-F Phase 2)。
# GATE_ENABLED=false
#
# GATE_MODEL: Layer 4 evaluator の Vertex Gemini モデル ID。既定は Vertex AI GA
#   `gemini-3.1-flash-lite` (2026-05-08 リリース、retirement 2027-05-07)。region
#   制約に注意 (`global` / `us` / `eu` のみ、`asia-northeast1` 非対応、CLOUD_ML_REGION=global
#   を維持)。latency 実測 (p50 目標 < 500ms) が超過した場合の差替候補は上位 flash 系 or
#   gemini-2.5-pro (料金増)。
# GATE_MODEL=gemini-3.1-flash-lite
#
# GATE_TIMEOUT_MS: Layer 4 evaluator の 1 リクエスト timeout。既定 3000ms
#   (fugue/patron の体感悪化を招かないための上限)。invalid (非数値 / 0 / 負数) は
#   warn + default fallback。
# GATE_TIMEOUT_MS=3000
#
# GATE_ADMIN_NOTIFY_DEBOUNCE_MS: in-secure 検知時の admin DM 通知の debounce window
#   (同一 admin userId への連続通知抑制)。既定 3000ms (attack 継続時の spam 抑止)。
#   in-memory Map<userId, lastSentAt> はプロセス再起動で消失 (稀ケース、罠 5)。
# GATE_ADMIN_NOTIFY_DEBOUNCE_MS=3000
#
# GATE_AUDIT_LOG_PATH: `.jsonl` local fallback の出力先。既定 `data/gate-audit.jsonl`
#   (mode `0o600`、初回のみ writeFileSync で明示 create、以降は appendFileSync)。
#   Cloud Logging → BQ sink は本 env に影響されず継続発火 (GCP は sink 経由が主、
#   local docker は `.jsonl` fallback で「残せる」)。
# GATE_AUDIT_LOG_PATH=data/gate-audit.jsonl
#
# GATE_AUDIT_LOG_DISABLE: '1' で local `.jsonl` fallback を無効化 (GCP 環境で
#   emptyDir にしか書けない `.jsonl` を書きたくない場合の退路)。Cloud Logging 経路
#   は本 env に影響されず継続発火。
# GATE_AUDIT_LOG_DISABLE=

# === M4-F Phase 3: life-capabilities (Web 検索 + Google Drive) ==============
# hybrid 経路 agent-container の MCP server (`tavily-mcp` + 自作 Drive server)
# が呼ぶ外部 API の認可を OneCLI vault で集約するための secret。詳細は
# `docs/operations-runbook.md` §M4-F Phase 3 を参照。
#
# TAVILY_API_KEY: Tavily Web 検索 API key (無料枠 1,000 credits/月)。
#   取得: https://tavily.com/ → account 作成 (Google/GitHub OAuth 可) → Dashboard → API keys
#
#   ## 取得順序 (primary = Secret Manager、fallback = env)
#   `scripts/onecli-tavily-secret.sh:resolve_tavily_key()` が env → Secret Manager → fail の
#   順で解決する:
#     - primary: Secret Manager `biblio-tavily-api-key` (`terraform/tavily-secret/` module 管理、
#       GKE 経路の orchestrator Pod 内 gcloud + WI で自動取得、DEN さん kubectl exec 手作業不要)
#     - fallback (env、= 本行): local dev で gcloud SDK 不在 or SM 未 apply の緊急経路
#
#   ## local dev (Docker Compose): 本 .env に貼れば OK (SM 経路は skip)
#   ## GKE prod: **本 env は不要**。Terraform module を apply して SM 経路で運ぶ:
#     cd terraform/tavily-secret && TF_VAR_tavily_api_key='tvly-...' terraform apply
#     以降は script が Pod 内 gcloud で自動取得 = `.env` / envFrom 追加なし
#   空文字だと script は SM を試行、SM 未存在なら need() で fail-fast (silent skip なし)。
TAVILY_API_KEY=
#
# Drive 側の secret 投入は本 env を持たない。orchestrator Pod 内の drive-token-rotator
# sidecar が WI 経由で ADC token を取り、`scripts/onecli-drive-secret.sh` 経由で
# OneCLI に `hostPattern=www.googleapis.com` の secret として投入する (Vertex と同流儀、
# 40min 周期 = ADC TTL ~60min の 20min margin)。DEN さんが取扱う手作業は 2 つ:
#   (a) `gcloud services enable drive.googleapis.com --project=hajimari-ai-hackathon-2026` (1 回)
#   (b) 対象 Drive フォルダを GSA `biblio-orchestrator@hajimari-ai-hackathon-2026.iam.gserviceaccount.com`
#       に「閲覧者」で共有 (Drive の権限は IAM ではなく ACL のため Terraform 化不可)
