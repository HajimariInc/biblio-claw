# biblio-claw Dockerfile (host 用) の build context から除外。
# Dockerfile.sidecar build 時にも同じ context が使われるが、Dockerfile.sidecar の
# COPY は scripts/ のみ参照するため除外で問題なし。

# Build 成果物 / state ディレクトリ
node_modules
dist
groups
data
logs

# Git / IDE / メタファイル
.git
.gitignore
.dockerignore
.github
.husky
.nvmrc
.mcp.json

# 環境 / 秘密 (絶対に image に焼かない)
.env
.env.*
*.pem
*.key

# AI Agent 設定 / 非公開ドキュメント
.claude

# Docker 関連 (Dockerfile 本体は別途 docker build で参照される)
Dockerfile
Dockerfile.sidecar
docker-compose.yml

# Test / lint config (host runtime には不要)
vitest.config.ts
vitest.skills.config.ts

# 別 build target (agent-runner image は container/build.sh で別途 build)
container

# M4-H Phase 5: init-fugue-ask-agent.ts (orchestrator 側 script) が
# readFileSync するため system-prompts のみ例外的に build context に含める。
# `.dockerignore` の negation pattern は親ディレクトリを段階的に unignore する必要あり
# (Docker 既知挙動、`!container/agent-runner/src/system-prompts/**` 単独では親が exclude)。
!container/agent-runner
!container/agent-runner/src
!container/agent-runner/src/system-prompts
!container/agent-runner/src/system-prompts/**

# K8s manifest / setup (image には焼かない)
k8s
setup
docs

# Markdown / changelog (runtime 不要)
README.md
CHANGELOG.md
CLAUDE.md
CONTRIBUTING.md
